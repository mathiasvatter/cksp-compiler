
// pre transform
on persistence_changed
    call do_sth(1,2)
end on
function do_sth(param1: int, param2: int)
    message(param1 & param2)
end function

// post transform
on persistence_changed
    declare param1: int := 1
    declare param2: int := 2
    call do_sth()
end on
function do_sth()
    message(param1 & param2)
end function


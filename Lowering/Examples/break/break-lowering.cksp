// modelling the break keyword in ksp by using
// continue and an exit_flag

{-------------------------------------------------------------------------------------------
										Pre Lowering cksp
--------------------------------------------------------------------------------------------}

i := 0
while (i < 5)
    inc(i)
    if (i <= 3)
        break // break out of the loop
    end if
    message(i)
end while

{-------------------------------------------------------------------------------------------
										Post Lowering
--------------------------------------------------------------------------------------------}

declare EXIT_FLAG // generate local exit var with fresh name
i := 0
while (i < 5 and EXIT_FLAG = 0)
    inc(i)
    if (i <= 3)
        EXIT_FLAG := 1
        continue
    end if
    message(i)
end while


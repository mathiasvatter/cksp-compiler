
struct List
	declare values[10]: int[]
	declare next: List := nil

	function __init__(self, value: int[], next: List)
		self.values := value
		self.next := next
	end function
	
	// function some_method(self, ficki) 
	// 	message(ficki)	
	// end function
end struct

on init

	declare this_list := nil
	this_list := List(42, nil)

	// declare lists[5]: List[] := (nil)

	declare ui_slider sli(1,500)
	sli->text := "sdfkj"
	declare a: string
	a := sli->text * 3
	declare nda[2,4] := ((1,2,3,4),(5,6,7,8))
	nda := ((1,2,3,4),(5,6,7,8))
	nda[0, *] := (0)
	nda[*, 3] := (1,2,6)
	
	// message(ndarray[0,0,0])
	
	declare nda2[4,5,5]
	nda2[1,*,*] := (2,3,4,5,6)
	nda2[1,*,*] := (0)

	declare arr[4]
	nda[0, *] := arr

	const colorz
		a
		b
	end const

	// 	// As Declaration 1
	// list !all_fx_texts[,]
	// 	"Low Pass -12dB",		0,		 "Hz","Reso","%"	
	// 	"Low Pass -24dB",		"Cutoff","Hz","Reso","%"	

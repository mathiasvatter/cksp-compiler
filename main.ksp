struct List
	declare value: int
	declare next: List

    function get_next_next_value(self)
        return self.next.next.value
    end function

	function add(self, value: int)
		self.next := List(value, nil)
	end function
end struct

struct Node
	declare value: int
	declare left: Node
	declare right: Node
end struct 

struct Point
	declare x: int
	declare y: int

	function __init__(self, x: int, y: int)
		self.x := x
		self.y := y
	end function

	function __repr__(self)
		return "Point {X: " & self.x & ", Y: " & self.y & "}"
	end function

	function __add__(self, other: Point)
		return Point(self.x + other.x, self.y + other.y)
	end function
end struct

define NUM_DYN_GROUPS := 10

struct Note
	declare pitch: int
	declare velocity: int
	declare groups[NUM_DYN_GROUPS]: int[]

	function __init__(self, p: int, v: int, g: int[])
		self.pitch := p
		self.velocity := v
		self.groups := g
	end function

	function __repr__(self): string
		return "Note {Pitch: " & self.pitch & ", Velocity: " & self.velocity & "}"
	end function

	function play(self): int
		return play_note(self.pitch, self.velocity, 0, 0)
	end function

	function get_groups(self): int[]
		return self.groups
	end function

end struct

struct Group
	declare const MAX_GROUPS := 10
	declare idx: int
	declare files[self.MAX_GROUPS]: string[]
	declare zone_ids[self.MAX_GROUPS]: int[]

	function add_zone(self, zone_id: int) : void
		self.zone_ids[0] := zone_id
	end function		


end struct


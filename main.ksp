namespace UI

	declare const HEIGHT := 100
	declare const WIDTH := 500

	function set_bg_frame(frame: int)
		set_skin_offset(frame * HEIGHT)
	end function

	namespace Layout
		function content_height(): int
            return HEIGHT-68        // unqualified access to outer member
        end function
	end namespace

	namespace Color
		declare const RED := 0xFF0000
		declare const GREEN := 0x00FF00
		declare const BLUE := 0x0000FF
		declare const WHITE := 0xFFFFFF
		declare const BLACK := 0x000000

		function set_background_color(hex: int)
			set_ui_color(hex)
		end function

	end namespace

	namespace Fonts

		declare types: int[] := [CONTROL_PAR_FONT_TYPE, CONTROL_PAR_FONT_TYPE_ON, CONTROL_PAR_FONT_TYPE_OFF_PRESSED, CONTROL_PAR_FONT_TYPE_ON_PRESSED, CONTROL_PAR_FONT_TYPE_OFF_HOVER, CONTROL_PAR_FONT_TYPE_ON_HOVER]
		declare button: string[] := ["off", "on", "off_pressed", "on_pressed", "off_hover", "on_hover"]

		function apply(ref ui_control, font_array: int[])
			for u in range(num_elements(types))
				set_control_par(ui_control, types[u], font_array[u])
			end for
		end function
	   
	end namespace
   
end namespace


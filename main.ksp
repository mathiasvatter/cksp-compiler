struct Event
	id: int

	function set_velocity(self, val: int)
		set_event_par(self.id, EVENT_PAR_VELOCITY, val)
	end function

	function set_pan(self, val: int)
		set_event_par(self.id, EVENT_PAR_PAN, val)
	end function
end struct

function playstep(): Event
	declare id := play_note(60, 127, 0, -1)
	return new Event(id)
end function

on note
	declare ev := playstep()
	ev.set_velocity(420)
	ev.set_pan(1000)
end on


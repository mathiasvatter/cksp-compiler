#pragma output_path("test.txt")
#pragma combine_callbacks(true)
#pragma max_callback_depth(420)

// #pragma optimize("none")

function load(array1: int[])
    declare tmp[num_elements(array1)]: int[]
    for idx, val in pairs(array1)
        tmp[idx] := val
    end for
	return tmp
end function



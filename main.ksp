function floatmask.set_range(float_mask, start_idx, end_idx, val)
    bitlist.set_range(float_mask[0], min(32, start_idx), min(32, end_idx), val)
	bitlist.set_range(float_mask[1], max(32, start_idx)-32, max(32, end_idx)-32, val)
end function



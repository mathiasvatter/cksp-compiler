function ret_sth()
	declare b[5] := (0)
	return 1, b
end function

function ndarray_func(ndarray: int[][])
	message(ndarray[0,0])
end function

on persistence_changed
	declare array[5]
	scoped_func1()
end on

function scoped_func1()
	declare text := "sdlkj"
	message(text)
	scoped_func2()
	declare array[4] := (3,4)
end function

function scoped_func2()
	declare i: int
	message(i)
	if(i = 1)
		declare arr[5]: int[] := (1)
		declare j: int, k: int
		message(j & k & arr[4])
	end if
	if(i = 2)
		declare h: int, g: int
		message(h & g)
	end if
end function




end function	


function search_matrix(matrix: int[][], target: int)
	declare array[30] := (0)

    declare row, col: int
    for row := 0 to matrix.SIZE_D1 - 1
        for col := 0 to matrix.SIZE_D2 - 1
            if matrix[row,col] = target
                return (row * 10) + col
            end if
        end for
    end for

    return -1  // If the target is not found
end function




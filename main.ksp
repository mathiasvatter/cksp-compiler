#pragma output_path("test.txt")
#pragma combine_callbacks(true)
#pragma max_callback_depth(420)
// #pragma optimize("none")




struct Point
    x: int, y: int

    function move_by(self, x: int, y: int)
        self.x += x
        self.y += y
        return new Point(x, y)
    end function        
end struct    

declare new_point := new Point(1,2).move_by(1,2)

on init
    do_sth(new Point(1,2).move_by(1,2))
end on

function do_sth(p: Point)
    message(p)
end function

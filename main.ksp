struct List
	declare note : Note
	declare next : List
end struct

struct Note
	declare pitch: int
	declare velocity: int
end struct



on init

end on


on note
	declare pitch: int := EVENT_NOTE
	declare velo: int := EVENT_VELOCITY
	play_note(pitch, clamp(velo, 90), 0, -1)
end on

function clamp(value: int, max: int) : int
	declare final :int := value
	if(value < 0)
		final := 0
	else if (value > max)
		final := max
	end if
	return final
end function


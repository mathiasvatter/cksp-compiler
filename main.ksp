#pragma output_path("test.txt")
#pragma combine_callbacks(true)
#pragma max_callback_depth(420)

// #pragma optimize("none")
struct Note
	pitch: int
	velo: int

	function get_velo(self)
		return self.velo
	end function

	function get_velo(self) override
		return self.pitch
	end function
end struct

declare Note := new Note(60, 127)

namespace BrowserFont
	declare types: int[] := [
		CONTROL_PAR_FONT_TYPE, 
		CONTROL_PAR_FONT_TYPE_ON, 
		CONTROL_PAR_FONT_TYPE_OFF_PRESSED, 
		
		CONTROL_PAR_FONT_TYPE_ON_PRESSED, 
		CONTROL_PAR_FONT_TYPE_OFF_HOVER, 
		CONTROL_PAR_FONT_TYPE_ON_HOVER
	]
	declare ty: int[] := types

	function get_type(idx: int) : int 
		return types[idx]
	end function

	function get_type(dd: int) : int override
		message("getting it!!!!!")
		return types[dd]
	end function
end namespace



function get_active_idx(value_array, emitter) -> result
    result := value_array[emitter,0]*0+value_array[emitter,1]*1+value_array[emitter,2]*2
end function

function return_size(ndarray: int[])
	return num_elements(ndarray)
end function	


function return_init(init: int[]): int[]
	message(init)
	return (1,2,3,4,5)
end function


function search_matrix(matrix: number[][], target: number): number
	declare array[30] := (0)
	declare ndarray[2,3]
	// declare ui_slider sli(0,1)
	message(num_elements(ndarray))
    declare row, col: int
    for row := 0 to num_elements(matrix, 1)- 1
        for col := 0 to num_elements(matrix, 2)- 1
            if matrix[row,col] = target
                return (row * 10) + col
            end if
        end for
    end for

    return -1  // If the target is not found
end function

function substitution(val: int, arr: int[])
	declare val3: int
	declare arr1[10] := arr
	// val := 1
	// inc(val)
	return val
end function	



struct Engine
	declare group[100]: Group[]
	declare send: Send
	declare bus[16]: Bus[]

	function __init__(self)
		for id, gr in pairs(self.group)
			gr := new Group(id)
		end for
		self.send := new Send()
		for id, bs in pairs(self.bus)
			bs := new Bus(id)
		end for
	end function
end struct 

struct Group
	declare slot[8]: Slot[]
	function __init__(self, group_idx: int)
		for id, sl in pairs(self.slot)
			sl := new Slot(id, group_idx, -1)
		end for
	end function
end struct

struct Bus
	declare slot[8]: Slot[]
	function __init__(self, bus_idx: int)
		for idx, sl in pairs(self.slot)
			sl := new Slot(idx, -1, NI_BUS_OFFSET + bus_idx)
		end for
	end function
end struct

struct Send
	declare slot[8]: Slot[]
	function __init__(self)
		for idx, sl in pairs(self.slot)
			sl := new Slot(idx, -1, NI_SEND_BUS)
		end for
	end function
end struct

struct Slot
	slot_idx: int
	group_idx: int
	bus_idx: int

	function __init__(self, slot_idx: int, group_idx: int, bus_idx: int)
		self.slot_idx := slot_idx
		self.group_idx := group_idx
		self.bus_idx := bus_idx
	end function

	add_engine_par_method(volume, VOLUME)
	// .... your other engine par methods here
	macro add_engine_par_method(#short_name#, #param#)
		function set_#short_name#(self, value: int)
			set_engine_par(ENGINE_PAR_#param#, value, self.group_idx, self.slot_idx, self.bus_idx)
		end function
		function get_#short_name#(self): int
			return get_engine_par(ENGINE_PAR_#param#, self.group_idx, self.slot_idx, self.bus_idx)
		end function
	end macro
end struct



{*******************************************************************************************************************
												* MACROS *
*******************************************************************************************************************}



function bitlist.set_range(bit_list, start_idx, end_idx, val)
	bit_list := eq(val, 1) * (eq(end_idx-start_idx, 32) * sh_right(-1, 32) + (bit_list .or. sh_left(.not. sh_left(-1, end_idx-start_idx), 32-end_idx))) + eq(val, 0) * (lt(end_idx-start_idx, 32) * (bit_list .and. .not. sh_left(.not. sh_left(-1, end_idx-start_idx), 32-end_idx)))
end function

function max(a,b) -> result
	result := a - ((a - b) .and. sh_right((a - b), 31))
end function

function min(a,b) -> result
	result :=  a - ((a - b) .and. sh_right((b - a), 31))
end function

function eq(a,b) -> result
  result := -sh_right(abs(a-b)-1,31)
end function

function lt(a,b) -> result  { predicate for a < b }
  result := -sh_right(a-b,31)
end function
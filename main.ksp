
function update.strip.noAutomation(btn_name, UI_array,value_array, emitter)
	for i := 0 to UI_array.SIZE_D2-1
		if UI_array[emitter,i] # get_ui_id(btn_name)
			UI_array[emitter,i] -> value := FALSE
		else 
			UI_array[emitter,i] -> value := TRUE
		end if
		value_array[emitter,i] := UI_array[emitter,i] -> value
	end for
end function


\usepackage{listings}
\usepackage{xcolor}

\lstdefinelanguage{CKSP}{
  sensitive=true,
  keywords=[1]{
    START_INC, END_INC, SET_CONDITION, RESET_CONDITION, USE_CODE_IF, USE_CODE_IF_NOT, END_USE_CODE,
    NO_SYS_SCRIPT_GROUP_START, NO_SYS_SCRIPT_PEDAL, NO_SYS_SCRIPT_RLS_TRIG, import, as, \#pragma, output_path,
    define, iterate_macro, literate_macro, continue, for, in, to, steps, end, if, else, select, case, while, macro, struct, self, end, list, const, family,
    function, end function, override, return, on, end on, async_complete, controller,
    init, listener, note, persistence_changed, pgs_changed, poly_at, release, rpn, nrpn, ui_control, ui_update, midi_in,
    ui_controls, family, end family, list, end list, macro, end macro
  },
  comment=[l]{//},
  morecomment=[s]{/*}{*/},
  morecomment=[s]{\\\{}{\}},
  morestring=[b]",
  morestring=[b]',
  keywords=[2]{int, float, bool, string},
  keywords=[3]{true, false},
  keywords=[4]{declare, read, pers, instpers, local, global, polyphonic, ui_button, ui_file_selector, ui_label, ui_knob,
  ui_level_meter, ui_menu, ui_mouse_area, ui_panel, ui_slider, ui_switch, ui_table, ui_text_edit, ui_value_edit,
  ui_waveform, ui_wavetable, ui_xy}, 
  keywords=[5]{\.and\., .or., .xor., .not., and, or, not, xor, mod},
  keywords=[6]{
    set_bounds, set_button_properties, set_knob_properties, set_label_properties, set_level_meter_properties,
    set_menu_properties, set_slider_properties, set_switch_properties, set_table_properties, set_text_edit_properties,
    set_value_edit_properties, set_waveform_properties, set_wavetable2d_properties, set_wavetable3d_properties,
    _get_engine_par, _get_engine_par_disp, _get_folder, _load_ir_sample, _num_slices, _pgs_create_key, _pgs_get_key_val,
    _pgs_key_exists, _pgs_set_key_val, _read_persistent_var, _reset_rls_trig_counter, _set_engine_par, _set_skin_offset,
    _slice_idx_loop_end, _slice_idx_loop_start, _slice_length, _slice_loop_count, _slice_start, _will_never_terminate,
    abs, acos, add_menu_item, add_text_line, allow_group, array_equal, asin, atan, attach_level_meter, attach_zone,

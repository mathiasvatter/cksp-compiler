    wait_async, watch_var, watch_array_idx, wait_ticks, will_never_terminate, zone_slice_idx_loop_end,
    zone_slice_idx_loop_start, zone_slice_length, zone_slice_loop_count, zone_slice_start, int_to_real, real,
    real_to_int, int, set_nks_nav_par, get_nks_nav_par, set_nks_nav_name, get_nks_nav_name
  },
  literate={
    % {0}    {{{\color{magenta}0}}}{1}
    % {1}    {{{\color{magenta}1}}}{1}
    % {2}    {{{\color{magenta}2}}}{1}
    % {3}    {{{\color{magenta}3}}}{1}
    % {4}    {{{\color{magenta}4}}}{1}
    % {5}    {{{\color{magenta}5}}}{1}
    % {6}    {{{\color{magenta}6}}}{1}
    % {7}    {{{\color{magenta}7}}}{1}
    % {8}    {{{\color{magenta}8}}}{1}
    % {9}    {{{\color{magenta}9}}}{1}
    {:}   {{{\color{mysymbol}:}}}{1}
    {:=}   {{{\color{mysymbol}:=}}}{1}
    {->}   {{{\color{mysymbol}->}}}{1}
    {=}    {{{\color{mysymbol}=}}}{1}
    {<}    {{{\color{mysymbol}<}}}{1}
    {>}    {{{\color{mysymbol}>}}}{1}
    {<=}   {{{\color{mysymbol}<=}}}{1}
    {>=}   {{{\color{mysymbol}>=}}}{1}
    {\#}    {{{\color{mysymbol}\#}}}{1}
    {+}    {{{\color{mysymbol}+}}}{1}
    {-}    {{{\color{mysymbol}-}}}{1}
    % {*}    {{{\color{mysymbol}*}}}{1}
    % {/}    {{{\color{mysymbol}/}}}{1}
    {\&}    {{{\color{mysymbol}\&}}}{1}
    % {(}    {{{\color{mysymbol}(}}}{1}
    % {)}    {{{\color{mysymbol})}}}{1}
    % {[}    {{{\color{mysymbol}[}}}{1}
    % {]}    {{{\color{mysymbol}]}}}{1}
    % {\.and\.}    {{{\color{myboolean}{.and.}}}}{1}
    % {.or.}    {{{\color{myboolean}.or.}}}{1}
    % {.xor.}    {{{\color{myboolean}.xor.}}}{1}
    % {.not.}    {{{\color{myboolean}.not.}}}{1}
  }
}

\definecolor{mycomment}{RGB}{80,90,80}     % Farbe für comment
\definecolor{mykeyword}{RGB}{175,109,169}     % Farbe für Keywords
\definecolor{mybuiltin}{RGB}{61,150,157}   % Farbe für builtin Funktionen 
\definecolor{mydeclare}{RGB}{67,134,202}     % Farbe für Deklarationen
\definecolor{myboolean}{RGB}{60,60,60}   % Farbe für Booleans
\definecolor{mysymbol}{RGB}{60,60,60}   % Farbe für symbols
% \definecolor{mybooleanop}{RGB}{67,134,202}   % Farbe für Booleans operators
\definecolor{mybooleanop}{RGB}{60,60,60}   % Farbe für Booleans operators
\definecolor{mytype}{RGB}{61,150,157}        % Farbe für Typen
\definecolor{mynumber}{RGB}{171,71,188}     % Farbe für Zahlen
\definecolor{mystring}{RGB}{192,123,85}     % Farbe für Strings

\lstdefinestyle{coloredCKSP} {
  keywordstyle=[1]\color{mykeyword}\bfseries, %keyword
  keywordstyle=[2]\color{mytype}, %type
  keywordstyle=[3]\color{myboolean}, %booleans
  keywordstyle=[4]\color{mydeclare}\bfseries, %declarekeywords
  keywordstyle=[5]\color{mybooleanop}, %boolean operators
  keywordstyle=[6]\color{mybuiltin}, %builtin functions
  commentstyle=\color{mycomment},
  stringstyle=\color{mystring},
}

\definecolor{mykeywordbasic}{RGB}{50,50,50}     % Farbe für Keywords in basic
\definecolor{mycommentbasic}{RGB}{90,110,60}     % Farbe für comment in basic
\definecolor{mystringbasic}{RGB}{110,75,50}     % Farbe für Strings in basic

\lstdefinestyle{basicCKSP} {
  keywordstyle=[1]\color{mykeywordbasic}\bfseries, %keyword
  keywordstyle=[2]\color{mysymbol}, %type
  keywordstyle=[3]\color{mysymbol}, %booleans
  keywordstyle=[4]\color{mykeywordbasic}\bfseries, %declarekeywords
  keywordstyle=[5]\color{mysymbol}, %boolean operators
  keywordstyle=[6]\color{mykeywordbasic}\bfseries, %builtin functions
  commentstyle=\color{mycommentbasic},
  stringstyle=\color{mystringbasic},
}


